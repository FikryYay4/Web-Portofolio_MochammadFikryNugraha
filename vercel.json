{
  "buildCommand": "bash vercel-build.sh",
  "outputDirectory": ".vercel/output",
  "devCommand": "python wsgi.py",
  "installCommand": "pip install -r requirements.txt",
  "functions": {
    "wsgi.py": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/static/(.*)",
      "destination": "/static/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/wsgi.py"
    }
  ],
  "env": {
    "FLASK_DEBUG": "false"
  }
}