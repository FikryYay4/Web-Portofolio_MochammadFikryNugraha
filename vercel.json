{
  "framework": "flask",
  "buildCommand": "pip install -r requirements.txt",
  "outputDirectory": ".",
  "devCommand": "python wsgi.py",
  "installCommand": "pip install -r requirements.txt",
  "functions": {
    "wsgi.py": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/static/(.*)",
      "destination": "/static/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/wsgi.py"
    }
  ],
  "includeFiles": [
    "templates/**",
    "static/**"
  ],
  "env": {
    "FLASK_DEBUG": "false"
  }
}