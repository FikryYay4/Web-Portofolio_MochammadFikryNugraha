{
  "functions": {
    "wsgi.py": {
      "maxDuration": 30,
      "includeFiles": [
        "templates/**",
        "static/**"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/wsgi.py"
    }
  ],
  "env": {
    "VERCEL": "1",
    "FLASK_DEBUG": "false"
  }
}